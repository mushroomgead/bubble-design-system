{
  "name": "@bubble-design-system/ui",
  "version": "1.2.2",
  "description": "Bubble Design System — soft + teal floating-pill UI on Base UI, with token-driven theming and a single shipped stylesheet (no Tailwind required).",
  "keywords": [
    "react",
    "design-system",
    "base-ui",
    "bubble",
    "bubble-design-system",
    "components",
    "ui",
    "headless",
    "tokens",
    "css-variables"
  ],
  "homepage": "https://github.com/mushroomgead/bubble-design-system#readme",
  "bugs": {
    "url": "https://github.com/mushroomgead/bubble-design-system/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mushroomgead/bubble-design-system.git",
    "directory": "packages/ui"
  },
  "author": "mushroomgade <mushroom.gead@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./assets/*": "./dist/assets/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "./dist/tokens.css"
  ],
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs && mkdir -p dist/assets && cp src/assets/*.svg dist/assets/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "npm-publish": "npm publish --access public"
  },
  "peerDependencies": {
    "react": ">=18.2",
    "react-dom": ">=18.2",
    "@base-ui/react": ">=1.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
